use strict;
use warnings;
use Irssi;
use IO::Socket::INET;

our $VERSION = '0.3.0';
our %IRSSI = (
    authors     => 'matrirc',
    name        => 'matrirc',
    description => 'Auto-start, supervise, and reconnect the matrirc daemon',
    license     => 'GPL-3.0-or-later',
);

my $BIN       = '__MATRIRC_BIN__';
my ($HOST, $PORT) = ('127.0.0.1', 6667);
if (my $bind = $ENV{MATRIRC_BIND}) {
    if ($bind =~ /^(.+):(\d+)$/) {
        ($HOST, $PORT) = ($1, $2 + 0);
    }
}
my $STATE_DIR = "$ENV{HOME}/.local/state/matrirc";
my $LOG       = "$STATE_DIR/log";
my $PID_FILE  = "$STATE_DIR/daemon.pid";

# How often we re-check daemon health.
my $POLL_MS     = 5000;
# Minimum seconds between spawn attempts — guards against crash loops.
my $SPAWN_GRACE = 5;

my $poll_id;
my $spawn_cooldown = 0;
my $initial_connect_done = 0;
my $last_state      = 'unknown';  # connected | starting | down | unknown
my $unload_requested = 0;
# Track whether this script spawned the current daemon, so we only stop it
# on unload if we started it (leaves pre-existing daemons alone).
my $spawned_by_us    = 0;

sub daemon_alive {
    my $sock = IO::Socket::INET->new(
        PeerHost => $HOST,
        PeerPort => $PORT,
        Proto    => 'tcp',
        Timeout  => 1,
    );
    return 0 unless $sock;
    close $sock;
    return 1;
}

sub have_irc_connection {
    for my $s (Irssi::servers()) {
        return 1 if $s->{address} eq $HOST && $s->{port} == $PORT;
    }
    # Reconnecting/handshaking servers don't show up in servers() until
    # registration completes; check the reconnection queue too so we don't
    # fire a duplicate `connect matrirc` mid-handshake.
    if (defined &Irssi::reconnects) {
        for my $r (Irssi::reconnects()) {
            return 1 if $r->{address} eq $HOST && $r->{port} == $PORT;
        }
    }
    return 0;
}

sub read_pid {
    open(my $fh, '<', $PID_FILE) or return undef;
    my $pid = <$fh>;
    close $fh;
    return unless defined $pid;
    $pid =~ s/\s+//g;
    return $pid =~ /^\d+$/ ? $pid + 0 : undef;
}

sub pid_is_alive {
    my $pid = shift;
    return kill(0, $pid) ? 1 : 0;
}

sub spawn_daemon {
    my $now = time();
    return if $spawn_cooldown > $now;
    $spawn_cooldown = $now + $SPAWN_GRACE;
    system("mkdir -p '$STATE_DIR'");
    system("nohup '$BIN' run >>'$LOG' 2>&1 </dev/null &");
    $spawned_by_us = 1;
}

sub kill_daemon_if_ours {
    return unless $spawned_by_us;
    my $pid = read_pid();
    return unless defined $pid && pid_is_alive($pid);
    Irssi::print("matrirc: sending SIGTERM to daemon (pid $pid)");
    kill('TERM', $pid);
}

sub set_state {
    my ($new, $msg) = @_;
    return if $new eq $last_state;
    Irssi::print($msg) if defined $msg;
    $last_state = $new;
}

sub ensure_chatnet {
    for my $n (Irssi::chatnets()) {
        return if $n->{name} eq 'matrirc';
    }
    Irssi::command("network add matrirc");
    Irssi::command("server add -auto -network matrirc $HOST $PORT");
}

sub poll {
    return if $unload_requested;

    my $alive = daemon_alive();

    if (!$alive) {
        set_state('down',
            "%Rmatrirc%n daemon is down (port $PORT unreachable). Restarting — log at $LOG");
        spawn_daemon();
        return;
    }

    if (!$initial_connect_done) {
        set_state('starting', 'matrirc: daemon up, connecting');
        ensure_chatnet();
        Irssi::command("connect matrirc");
        $initial_connect_done = 1;
        return;
    }

    if (have_irc_connection()) {
        set_state('connected', 'matrirc: connected');
    }
    # If connection is gone, irssi's native auto-reconnect handles it.
    # Issuing another `connect matrirc` here races with the reconnect queue
    # and produces duplicate servers (matrirc2, matrirc3, …).
}

sub start {
    poll();
    $poll_id = Irssi::timeout_add($POLL_MS, 'poll', undef);
}

sub stop {
    $unload_requested = 1;
    Irssi::timeout_remove($poll_id) if $poll_id;
    $poll_id = undef;
    kill_daemon_if_ours();
}

# --- IRCv3 msgid rendering -----------------------------------------------
# Reads matrirc's `@msgid=...` tag and prefixes `[xxxx]` on incoming bodies
# so the user can target replies with `!r <id> <text>`. `/set matrirc_msgid_debug ON`
# logs signal traffic.
Irssi::settings_add_bool('matrirc', 'matrirc_msgid_debug', 0);
sub msgid_debug { Irssi::settings_get_bool('matrirc_msgid_debug') }

# irssi blesses a fresh `$server` per signal call, so attributes hung off
# `$server->{...}` don't survive between handlers. Use a script-lexical hash
# keyed by `server->{tag}` instead.
my %msgid_pending;
sub msgid_state_key { $_[0]->{tag} . '|' . $_[1] }

# matrirc accepts CAP REQ post-registration; server-time is enough because
# matrirc silently bundles message-tags into the ACK.
sub msgid_on_welcome {
    my ($server) = @_;
    return unless $server;
    # Skip echo-message: irssi's local-echo suppression is unreliable and
    # users end up seeing every outbound line twice. The reply-quote line
    # comes through a NOTICE path that doesn't need echo-message.
    $server->send_raw_now('CAP REQ :server-time message-tags');
}

# Queue msgid per stream (channel for pubmsg, sender-nick for DM). Ordering
# stays in sync because irssi processes each incoming line synchronously:
# server_incoming → message_public / message_private. Don't key on body —
# irssi may trim/normalise before the message signal fires.
sub msgid_queue_key {
    my ($target, $nick) = @_;
    # Include sender in the channel key so your own echo-message bounces
    # (untagged, key=chan|#room|self) can't pop a remote sender's queue.
    return substr($target, 0, 1) eq '#'
        ? 'chan|' . lc($target) . '|' . lc($nick)
        : 'dm|' . lc($nick);
}

sub msgid_unescape_tag {
    my ($v) = @_;
    $v =~ s/\\:/;/g; $v =~ s/\\s/ /g; $v =~ s/\\\\/\\/g;
    $v =~ s/\\r/\r/g; $v =~ s/\\n/\n/g;
    $v;
}

sub msgid_on_server_incoming {
    my ($server, $line) = @_;
    return unless defined $line && substr($line, 0, 1) eq '@';
    return unless $line =~ /^@([^ ]+)\s+:([^!\s]+)\S*\s+PRIVMSG\s+(\S+)(?:\s+:?(.*))?$/;
    my ($tags, $nick, $target, $body) = ($1, $2, $3, $4);
    # CTCP (`\x01`-wrapped) bodies route through `message irc action` / other
    # signals, not `message public/private`. Pushing here would leave the
    # msgid permanently unpopped → every later event displays the previous
    # one's id.
    if (defined $body && substr($body, 0, 1) eq "\x01") {
        return;
    }
    # ZNC-style DM replays (sender == own nick, target is our own nick or any
    # non-channel) crash irssi's query_find on signal_continue. For channels
    # they're harmless — own messages should render with `[id]` so the user
    # can target their own messages via `!r`.
    if (defined $server->{nick}
        && lc($nick) eq lc($server->{nick})
        && substr($target, 0, 1) ne '#')
    {
        return;
    }
    my $id;
    for my $kv (split /;/, $tags) {
        my ($k, $v) = split /=/, $kv, 2;
        if ($k eq 'msgid' && defined $v && length $v) { $id = msgid_unescape_tag($v); last; }
    }
    return unless defined $id;
    my $key = msgid_queue_key($target, $nick);
    push @{$msgid_pending{msgid_state_key($server, $key)}}, $id;
    Irssi::print("msgid push: key=$key id=$id (from $nick → $target)") if msgid_debug();
}

sub msgid_pop {
    my ($server, $key) = @_;
    my $q = $msgid_pending{msgid_state_key($server, $key)} or return;
    return shift @$q;
}

sub msgid_rewrite_public {
    my ($server, $msg, $nick, $address, $target) = @_;
    my $key = 'chan|' . lc($target) . '|' . lc($nick);
    my $id = msgid_pop($server, $key);
    Irssi::print("pubmsg: key=$key id=" . (defined $id ? $id : '(none)') . " nick=$nick")
        if msgid_debug();
    return unless defined $id;
    Irssi::signal_continue($server, "[$id] $msg", $nick, $address, $target);
}

sub msgid_rewrite_private {
    my ($server, $msg, $nick, $address, $target) = @_;
    my $key = 'dm|' . lc($nick);
    my $id = msgid_pop($server, $key);
    Irssi::print("privmsg: key=$key id=" . (defined $id ? $id : '(none)') . " nick=$nick")
        if msgid_debug();
    return unless defined $id;
    # `message private` carries five args in modern irssi; pass `target` along
    # so downstream handlers don't read garbage for the fifth parameter.
    Irssi::signal_continue($server, "[$id] $msg", $nick, $address, $target);
}

# Own messages in channels arrive on `message own_public` instead of
# `message public`. Pop the same per-(target, own-nick) queue so backfilled
# pawelb-in-#chan lines render `[id]` just like everyone else's.
sub msgid_rewrite_own_public {
    my ($server, $msg, $target, $orig_target) = @_;
    my $own = $server->{nick};
    return unless defined $own;
    my $key = 'chan|' . lc($target) . '|' . lc($own);
    my $id = msgid_pop($server, $key);
    Irssi::print("own_pubmsg: key=$key id=" . (defined $id ? $id : '(none)'))
        if msgid_debug();
    return unless defined $id;
    Irssi::signal_continue($server, "[$id] $msg", $target, $orig_target);
}

sub msgid_rewrite_irc_action {
    my ($server, $msg, $nick, $address, $target) = @_;
    # Match the same per-stream key as on_server_incoming, but actions are
    # CTCP-wrapped — we skipped the push for them, so this pop will normally
    # return undef. Kept symmetric in case a future change re-enables it.
    my $key = substr($target, 0, 1) eq '#'
        ? 'chan|' . lc($target) . '|' . lc($nick)
        : 'dm|' . lc($nick);
    my $id = msgid_pop($server, $key);
    Irssi::print("action: key=$key id=" . (defined $id ? $id : '(none)') . " nick=$nick")
        if msgid_debug();
    return unless defined $id;
    Irssi::signal_continue($server, "[$id] $msg", $nick, $address, $target);
}

Irssi::signal_add_first('event 001',             \&msgid_on_welcome);
Irssi::signal_add_first('server incoming',       \&msgid_on_server_incoming);
Irssi::signal_add_first('message public',        \&msgid_rewrite_public);
Irssi::signal_add_first('message private',       \&msgid_rewrite_private);
Irssi::signal_add_first('message own_public',    \&msgid_rewrite_own_public);
Irssi::signal_add_first('message irc action',    \&msgid_rewrite_irc_action);

# Mid-session reloads miss event 001, so REQ caps for live servers now.
for my $s (Irssi::servers()) {
    msgid_on_welcome($s) if $s->{connected};
}
# --- end IRCv3 msgid rendering -------------------------------------------

# Cheat sheet printed on script load so the same hints are visible whether you
# saw the MOTD or just `/script load`ed.
sub print_cheatsheet {
    Irssi::print('matrirc commands:');
    Irssi::print('  /msg matrirc help                  bot help');
    Irssi::print('  /msg matrirc rooms | dms           list bridged channels / DMs');
    Irssi::print('  /msg matrirc search <term>         public-room directory');
    Irssi::print('  /msg matrirc ids on|off|toggle     IRCv3 msgid tag for !r replies');
    Irssi::print('  /join #alias:server.org            join matrix room');
    Irssi::print('  /msg @user:server hi               DM by mxid');
    Irssi::print('  !r <id> text                       reply to message [id]');
    Irssi::print('  /join #echo                        local echo bot for testing');
}
print_cheatsheet();

Irssi::signal_add_last('script unload' => sub {
    my ($script) = @_;
    return unless $script->{name} eq $IRSSI{name};
    stop();
});

# If the daemon is already running when we load, assume the user started it
# externally; don't claim ownership.
if (defined read_pid() && pid_is_alive(read_pid())) {
    $spawned_by_us = 0;
}

start();
